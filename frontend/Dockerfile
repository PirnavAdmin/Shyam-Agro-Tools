FROM node:20-alpine AS build
WORKDIR /app

ARG REACT_APP_SITE_URL
ARG REACT_APP_AUTH_API_BASE_URL
ARG REACT_APP_CART_CHECKOUT_API_BASE_URL
ARG REACT_APP_WALLET_API_BASE_URL
ARG REACT_APP_SUPPORT_API_BASE_URL
ARG REACT_APP_TESTIMONIAL_API_BASE_URL
ARG REACT_APP_MANUAL_PAYMENT_MERCHANT_NAME
ARG REACT_APP_MANUAL_PAYMENT_UPI_ID
ARG REACT_APP_MANUAL_PAYMENT_ACCOUNT_HOLDER
ARG REACT_APP_MANUAL_PAYMENT_BANK_NAME
ARG REACT_APP_MANUAL_PAYMENT_ACCOUNT_NUMBER
ARG REACT_APP_MANUAL_PAYMENT_IFSC
ARG REACT_APP_MANUAL_PAYMENT_BRANCH

ENV REACT_APP_SITE_URL=$REACT_APP_SITE_URL
ENV REACT_APP_AUTH_API_BASE_URL=$REACT_APP_AUTH_API_BASE_URL
ENV REACT_APP_CART_CHECKOUT_API_BASE_URL=$REACT_APP_CART_CHECKOUT_API_BASE_URL
ENV REACT_APP_WALLET_API_BASE_URL=$REACT_APP_WALLET_API_BASE_URL
ENV REACT_APP_SUPPORT_API_BASE_URL=$REACT_APP_SUPPORT_API_BASE_URL
ENV REACT_APP_TESTIMONIAL_API_BASE_URL=$REACT_APP_TESTIMONIAL_API_BASE_URL
ENV REACT_APP_MANUAL_PAYMENT_MERCHANT_NAME=$REACT_APP_MANUAL_PAYMENT_MERCHANT_NAME
ENV REACT_APP_MANUAL_PAYMENT_UPI_ID=$REACT_APP_MANUAL_PAYMENT_UPI_ID
ENV REACT_APP_MANUAL_PAYMENT_ACCOUNT_HOLDER=$REACT_APP_MANUAL_PAYMENT_ACCOUNT_HOLDER
ENV REACT_APP_MANUAL_PAYMENT_BANK_NAME=$REACT_APP_MANUAL_PAYMENT_BANK_NAME
ENV REACT_APP_MANUAL_PAYMENT_ACCOUNT_NUMBER=$REACT_APP_MANUAL_PAYMENT_ACCOUNT_NUMBER
ENV REACT_APP_MANUAL_PAYMENT_IFSC=$REACT_APP_MANUAL_PAYMENT_IFSC
ENV REACT_APP_MANUAL_PAYMENT_BRANCH=$REACT_APP_MANUAL_PAYMENT_BRANCH

COPY package*.json ./
RUN npm ci
COPY . .
RUN npm run build

FROM nginx:1.27-alpine AS final
COPY nginx.conf /etc/nginx/conf.d/default.conf
COPY --from=build /app/build /usr/share/nginx/html
EXPOSE 80
CMD ["nginx", "-g", "daemon off;"]
